{
    "name": "Appearance",
    "description": "Switch between light and dark mode",
    "version": "1.0.0",
    "manifest_version": 3,
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Appearance",
        "default_popup": "popup.html"
    },
    "permissions": [
        "tabs",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "web_accessible_resources": [{
        "resources": ["appOn.js", "appOff.js"],
        "matches": ["https://*/*", "http://*/*"]
    }]
}